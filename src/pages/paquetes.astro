---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const base = "https://harol2000.github.io/page_photography/";

const packages = [
  {
    title: "Sesión de Novios",
    subtitle: "before your wedding",
    image: `${base}images/624535049_122108716299204129_1624264578338389553_n.jpg`,
    hoverImage: `${base}images/623917170_122108717205204129_8828546668175769016_n.jpg`,
    link: `${base}paquetes/sesion-novios/`,
  },
  {
    title: "Cobertura de Bodas",
    subtitle: "",
    image: `${base}images/622359896_122108711961204129_8171615373665783138_n.jpg`,
    hoverImage: `${base}images/622727017_122108717235204129_6272086216731972065_n.jpg`,
    link: `${base}paquetes/cobertura-bodas/`,
  },
  {
    title: "Video de Bodas",
    subtitle: "memories",
    image: `${base}images/624228533_122108712555204129_7475938911244930771_n.jpg`,
    hoverImage: `${base}images/624242715_122108716407204129_6930061170870102698_n.jpg`,
    link: `${base}paquetes/video-bodas/`,
  },
  {
    title: "Premium Experience",
    subtitle: "",
    image: `${base}images/622620831_122108715999204129_4721692470404525508_n.jpg`,
    hoverImage: `${base}images/624406731_122108717193204129_4519717868385406808_n.jpg`,
    link: `${base}paquetes/premium-experience/`,
  },
];
---

<MainLayout title="Paquetes | Tu Marca">
  <Header />

  <section class="section packages-section">
    <div class="container packages-container">
      <p class="eyebrow packages-eyebrow">Choose your story</p>

      <div class="packages-list">
        {packages.map((item, index) => (
          <a
            href={item.link}
            class={`package-banner ${index % 2 === 0 ? "narrow" : "wide"}`}
          >
            <div class="package-image-stack">
              <img src={item.image} alt={item.title} class="img-base" />
              <img src={item.hoverImage} alt={item.title} class="img-hover" />
            </div>

            <div class="package-overlay">
              <div class="package-copy">
                <h2>{item.title}</h2>
                {item.subtitle && <p class="package-subtitle">{item.subtitle}</p>}
                <span class="package-btn">Leer más</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  .packages-section {
    padding-top: 4rem;
  }

  .packages-container {
    max-width: 1100px;
  }

  .packages-eyebrow {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 1rem;
    letter-spacing: 0.06em;
    text-transform: none;
    color: #d8c1a6;
  }

  .packages-list {
    display: grid;
    gap: 1.4rem;
  }

  .package-banner {
    position: relative;
    display: block;
    overflow: hidden;
    margin-inline: auto;
    color: white;
    text-decoration: none;
    border-radius: 0;
  }

  .package-banner.narrow {
    width: 72%;
    min-height: 230px;
  }

  .package-banner.wide {
    width: 88%;
    min-height: 250px;
  }

  .package-image-stack {
    position: absolute;
    inset: 0;
  }

  .package-image-stack img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease, opacity 0.45s ease;
  }

  .img-base {
    opacity: 1;
    transform: scale(1);
  }

  .img-hover {
    opacity: 0;
    transform: scale(1.08);
  }

  .package-banner:hover .img-base {
    opacity: 0;
    transform: scale(1.06);
  }

  .package-banner:hover .img-hover {
    opacity: 1;
    transform: scale(1.12);
  }

  .package-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 2rem;
    background: linear-gradient(to top, rgba(0,0,0,.38), rgba(0,0,0,.08));
  }

  .package-copy {
    max-width: 420px;
  }

  .package-copy h2 {
    font-size: clamp(2rem, 3vw, 3.4rem);
    line-height: 0.95;
    font-weight: 300;
    margin-bottom: 0.7rem;
    color: white;
  }

  .package-subtitle {
    font-size: clamp(1.3rem, 2.2vw, 2.4rem);
    line-height: 0.95;
    font-weight: 300;
    color: rgba(255,255,255,.88);
    margin-bottom: 1rem;
  }

  .package-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 130px;
    padding: 0.75rem 1.1rem;
    border: 2px solid rgba(255,255,255,.95);
    border-radius: 999px;
    color: white;
    font-weight: 600;
    transition: background .25s ease, color .25s ease;
  }

  .package-banner:hover .package-btn {
    background: white;
    color: #222;
  }

  @media (max-width: 900px) {
    .package-banner.narrow,
    .package-banner.wide {
      width: 100%;
      min-height: 220px;
    }

    .package-overlay {
      padding: 1.3rem;
    }

    .package-copy h2 {
      font-size: 2rem;
    }

    .package-subtitle {
      font-size: 1.4rem;
    }
  }
</style>
