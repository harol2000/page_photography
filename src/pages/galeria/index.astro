---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { galleries } from "../../data/galleries";
import type { ImageMetadata } from "astro";

const base = import.meta.env.BASE_URL;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/galerias/**/*.{jpg,jpeg,png,webp}",
  { eager: true }
);

function getCover(slug: string): ImageMetadata | null {
  const match = Object.entries(allImages).find(([path]) =>
    path.includes(`/galerias/${slug}/`)
  );

  return match ? match[1].default : null;
}
---

<MainLayout title="Galería | Tu Marca">
  <Header />

  <section class="section">
    <div class="container">
      <div class="portfolio-grid">
        {galleries.map((gallery) => {
          const cover = getCover(gallery.slug);

          return (
            <a href={`${base}galeria/${gallery.slug}/`} class="portfolio-card">
              {cover && (
                <img
                  src={cover.src}
                  alt={gallery.title}
                  class="portfolio-image"
                />
              )}

              <div class="portfolio-overlay">
                <h2>{gallery.title}</h2>
                <span>Ver galería &gt;</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .portfolio-card {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
    min-height: 520px;
    box-shadow: var(--shadow);
  }

  .portfolio-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .4s ease;
  }

  .portfolio-card:hover .portfolio-image {
    transform: scale(1.04);
  }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: rgba(0,0,0,.18);
    color: white;
    text-align: center;
    padding: 1rem;
  }

  .portfolio-overlay h2 {
    font-size: 1.5rem;
    margin-bottom: .7rem;
    font-weight: 500;
  }

  .portfolio-overlay span {
    font-size: 1rem;
    font-weight: 600;
  }

  @media (max-width: 1100px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
    }

    .portfolio-card {
      min-height: 420px;
    }
  }
</style>
