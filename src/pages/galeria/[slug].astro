---
import type { ImageMetadata } from "astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { galleries } from "../../data/galleries";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  return galleries.map((gallery) => ({
    params: { slug: gallery.slug },
    props: { gallery }
  }));
}

const { gallery } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/galerias/**/*.{jpg,jpeg,png,webp,jfif}",
  { eager: true }
);

const images: ImageMetadata[] = Object.entries(allImages)
  .filter(([path]) => path.includes(`/galerias/${gallery.slug}/`))
  .map(([, mod]) => mod.default);

const imageUrls = images.map((img) => img.src);
---

<MainLayout title={`${gallery.title} | Portafolio`}>
  <Header />

  <section class="section">
    <div class="container">
      <p class="eyebrow">Portafolio</p>
      <h1 class="title">{gallery.title}</h1>
      <p class="text intro">{gallery.description}</p>

      <div class="gallery-grid">
        {images.map((image, index) => (
          <figure class="gallery-item">
            <button
              class="gallery-btn"
              type="button"
              data-index={index}
              aria-label={`Abrir imagen ${index + 1}`}
            >
              <img
                src={image.src}
                alt={`${gallery.title} ${index + 1}`}
                loading="lazy"
                style={`aspect-ratio: ${image.width} / ${image.height};`}
              />
            </button>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="lightbox-topbar">
      <div class="lightbox-meta">
        <span class="lightbox-kicker">Portafolio</span>
        <h2 id="lightbox-title">{gallery.title}</h2>
      </div>

      <div class="lightbox-top-actions">
        <span class="lightbox-counter" id="lightbox-counter">1 / {images.length}</span>

        <button
          class="lightbox-autoplay"
          id="lightbox-autoplay"
          type="button"
          aria-label="Activar o pausar reproduccion automatica"
        >
          Auto
        </button>

        <button class="lightbox-close" id="lightbox-close" type="button" aria-label="Cerrar">
          x
        </button>
      </div>
    </div>

    <button class="lightbox-nav lightbox-prev" id="lightbox-prev" type="button" aria-label="Anterior">
      &lt;
    </button>

    <div class="lightbox-stage">
      <img id="lightbox-image" src="" alt="Vista ampliada" />
    </div>

    <button class="lightbox-nav lightbox-next" id="lightbox-next" type="button" aria-label="Siguiente">
      &gt;
    </button>
  </div>

  <script define:vars={{ imageUrls, galleryTitle: gallery.title }}>
    const images = imageUrls;
    const galleryName = galleryTitle;

    const buttons = document.querySelectorAll(".gallery-btn");
    const lightbox = document.getElementById("lightbox");
    const lightboxImage = document.getElementById("lightbox-image");
    const closeBtn = document.getElementById("lightbox-close");
    const prevBtn = document.getElementById("lightbox-prev");
    const nextBtn = document.getElementById("lightbox-next");
    const counter = document.getElementById("lightbox-counter");
    const title = document.getElementById("lightbox-title");
    const autoplayBtn = document.getElementById("lightbox-autoplay");

    let currentIndex = 0;
    let autoSlide = null;
    let isAutoplayOn = false;
    let startX = 0;
    let endX = 0;

    function updateCounter() {
      counter.textContent = `${currentIndex + 1} / ${images.length}`;
    }

    function animateImageChange(newSrc) {
      lightboxImage.classList.remove("is-visible");
      setTimeout(() => {
        lightboxImage.src = newSrc;
      }, 120);
    }

    lightboxImage.addEventListener("load", () => {
      lightboxImage.classList.add("is-visible");
    });

    function showImage(index) {
      currentIndex = index;
      animateImageChange(images[currentIndex]);
      updateCounter();
      title.textContent = galleryName;
    }

    function openLightbox(index) {
      showImage(index);
      lightbox.classList.add("is-open");
      lightbox.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
      lightbox.classList.remove("is-open");
      lightbox.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      stopAutoSlide();
      isAutoplayOn = false;
      autoplayBtn.classList.remove("is-active");
    }

    function nextImage() {
      currentIndex = (currentIndex + 1) % images.length;
      showImage(currentIndex);
    }

    function prevImage() {
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      showImage(currentIndex);
    }

    function startAutoSlide() {
      stopAutoSlide();
      autoSlide = setInterval(() => {
        nextImage();
      }, 4000);
      isAutoplayOn = true;
      autoplayBtn.classList.add("is-active");
    }

    function stopAutoSlide() {
      if (autoSlide) {
        clearInterval(autoSlide);
        autoSlide = null;
      }
      isAutoplayOn = false;
      autoplayBtn.classList.remove("is-active");
    }

    function toggleAutoplay() {
      if (isAutoplayOn) {
        stopAutoSlide();
      } else {
        startAutoSlide();
      }
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const index = Number(btn.dataset.index);
        openLightbox(index);
      });
    });

    closeBtn.addEventListener("click", closeLightbox);
    nextBtn.addEventListener("click", nextImage);
    prevBtn.addEventListener("click", prevImage);
    autoplayBtn.addEventListener("click", toggleAutoplay);

    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) {
        closeLightbox();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (!lightbox.classList.contains("is-open")) return;

      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowRight") nextImage();
      if (e.key === "ArrowLeft") prevImage();
      if (e.key.toLowerCase() === " ") {
        e.preventDefault();
        toggleAutoplay();
      }
    });

    lightbox.addEventListener("touchstart", (e) => {
      startX = e.changedTouches[0].clientX;
    });

    lightbox.addEventListener("touchend", (e) => {
      endX = e.changedTouches[0].clientX;
      const diff = startX - endX;

      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          nextImage();
        } else {
          prevImage();
        }
      }
    });
  </script>

  <Footer />
</MainLayout>

<style>
  .intro {
    max-width: 700px;
    margin-bottom: 2rem;
  }

  .gallery-grid {
    columns: 3 18rem;
    column-gap: 1rem;
  }

  .gallery-item {
    margin: 0 0 1rem;
    break-inside: avoid;
    overflow: hidden;
    border-radius: 18px;
    box-shadow: var(--shadow);
    background: #ddd;
  }

  .gallery-btn {
    display: block;
    width: 100%;
    border: 0;
    background: none;
    padding: 0;
    cursor: zoom-in;
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .gallery-btn:hover img {
    transform: scale(1.03);
  }

  .lightbox {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(circle at top, rgba(255, 255, 255, 0.06), transparent 35%),
      rgba(8, 8, 8, 0.96);
    display: none;
    z-index: 9999;
    padding: 1rem;
  }

  .lightbox.is-open {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr) 72px;
    grid-template-rows: auto 1fr;
    align-items: center;
  }

  .lightbox-topbar {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 0 1rem;
    color: white;
  }

  .lightbox-meta h2 {
    font-size: clamp(1.2rem, 2vw, 1.7rem);
    font-weight: 700;
  }

  .lightbox-kicker {
    display: inline-block;
    margin-bottom: 0.3rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.72);
  }

  .lightbox-top-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .lightbox-counter,
  .lightbox-autoplay,
  .lightbox-close {
    border: 0;
    background: rgba(255, 255, 255, 0.12);
    color: white;
    backdrop-filter: blur(10px);
  }

  .lightbox-counter {
    padding: 0.72rem 1rem;
    border-radius: 999px;
    font-weight: 600;
  }

  .lightbox-autoplay {
    padding: 0.72rem 1rem;
    border-radius: 999px;
    cursor: pointer;
    font-weight: 700;
  }

  .lightbox-autoplay.is-active {
    background: rgba(255, 255, 255, 0.24);
  }

  .lightbox-close {
    width: 46px;
    height: 46px;
    border-radius: 999px;
    cursor: pointer;
    font-size: 1.1rem;
  }

  .lightbox-stage {
    grid-column: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
    height: calc(100vh - 120px);
  }

  .lightbox-stage img {
    max-width: min(92vw, 1200px);
    max-height: calc(100vh - 140px);
    object-fit: contain;
    border-radius: 16px;
    opacity: 0;
    transform: scale(0.985);
    transition: opacity 0.22s ease, transform 0.22s ease;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }

  .lightbox-stage img.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  .lightbox-nav {
    width: 56px;
    height: 56px;
    border-radius: 999px;
    border: 0;
    background: rgba(255, 255, 255, 0.14);
    color: white;
    cursor: pointer;
    font-size: 2rem;
    line-height: 1;
    backdrop-filter: blur(10px);
    justify-self: center;
  }

  .lightbox-prev {
    grid-column: 1;
  }

  .lightbox-next {
    grid-column: 3;
  }

  .lightbox-nav:hover,
  .lightbox-close:hover,
  .lightbox-autoplay:hover {
    background: rgba(255, 255, 255, 0.22);
  }

  @media (max-width: 1100px) {
    .gallery-grid {
      columns: 2 16rem;
    }
  }

  @media (max-width: 720px) {
    .gallery-grid {
      columns: 1;
    }

    .lightbox.is-open {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr auto;
    }

    .lightbox-topbar {
      grid-column: 1;
      align-items: flex-start;
      flex-direction: column;
    }

    .lightbox-stage {
      grid-column: 1;
      height: auto;
      align-self: center;
    }

    .lightbox-stage img {
      max-width: 100%;
      max-height: 72vh;
    }

    .lightbox-nav {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 46px;
      height: 46px;
      font-size: 1.6rem;
    }

    .lightbox-prev {
      left: 10px;
    }

    .lightbox-next {
      right: 10px;
    }

    .lightbox-close {
      position: absolute;
      top: 14px;
      right: 14px;
      z-index: 2;
    }
  }
</style>
