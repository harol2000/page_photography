---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const videos = [
  {
    title: "Hablemos de bodas...",
    subtitle: "Cinematics",
    description:
      "Una selección de piezas audiovisuales creadas para revivir emociones, atmósferas y momentos inolvidables.",
    youtube: "https://www.youtube.com/embed/qBS_c4g90aQ?si=IWvejIrWqmlbUXQv",
  },
  {
    title: "Love Stories",
    subtitle: "Fragmentos visuales",
    description:
      "Una pequeña colección de fragmentos en una cinematografía dedicada a los enamorados.",
    youtube: "https://www.youtube.com/embed/qBS_c4g90aQ?si=IWvejIrWqmlbUXQv",
  },
  {
    title: "Hablemos de bodas",
    subtitle: "Edición visual",
    description:
      "Una muestra de cómo los recuerdos también pueden contarse a través del movimiento, la música y la emoción.",
    youtube: "https://www.youtube.com/embed/qBS_c4g90aQ?si=IWvejIrWqmlbUXQv",
  },
];

const stories = [
  {
    title: "Patricia + Gabriel",
    text: '"Juntos somos perfectos".',
  },
  {
    title: "Patricia + Gabriel",
    text: "Entre café y caricias",
  },
  {
    title: "Jota + Carol",
    text: "Dos enamorados celebrando en grande.",
  },
  {
    title: "Giulia + Enrique",
    text: "Una muestra de amor incondicional.",
  },
  {
    title: "Ellery + Mitch",
    text: "Una emocionante unión en la playa.",
  },
  {
    title: "The Waltz go on",
    text: '"Uno de esos amores que son para siempre".',
  },
  {
    title: "Ev + Leo",
    text: "Una historia de película en NYC.",
  },
  {
    title: "Pamela + Bartolomé",
    text: '"Estamos destinados a pertenecernos".',
  },
];
---

<MainLayout title="Cinematics | Studio27">
  <Header />

  <section class="cinematics-page">
    <div class="container narrow hero-top">
      <p class="kicker">AUDIOVISUAL WEDDING STORIES</p>
      <h1 class="main-title">Cinematics</h1>
      <p class="intro">
        Hablemos de bodas, de recuerdos en movimiento y de historias que también merecen
        sentirse a través de la música, la voz, la emoción y la imagen.
      </p>
    </div>

    <div class="videos-section">
      {videos.map((video) => (
        <article class="video-card">
          <div class="video-frame">
            <iframe
              src={video.youtube}
              title={video.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
            ></iframe>
          </div>

          <div class="video-copy">
            <p class="section-label">{video.subtitle}</p>
            <h2>{video.title}</h2>
            <p>{video.description}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="container narrow stories-section">
      <p class="kicker">LOVE STORIES</p>
      <h2 class="stories-title">Una colección de historias</h2>

      <div class="stories-grid">
        {stories.map((story) => (
          <article class="story-card">
            <h3>{story.title}</h3>
            <p>{story.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap');

  .cinematics-page {
    padding: 4rem 0 0;
    font-family: 'Montserrat', sans-serif;
  }

  .narrow {
    max-width: 1120px;
    margin-inline: auto;
  }

  .hero-top {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .kicker {
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    color: #9b8f84;
    margin-bottom: 1rem;
  }

  .main-title {
    font-size: clamp(3rem, 5vw, 4.8rem);
    font-weight: 300;
    color: #8aa0a0;
    margin-bottom: 1rem;
    line-height: 1.08;
  }

  .intro {
    max-width: 820px;
    margin: 0 auto;
    font-size: 1.15rem;
    line-height: 1.9;
    color: #4f4a45;
  }

  .videos-section {
    max-width: 1500px;
    margin: 0 auto 5rem;
    display: grid;
    gap: 2.8rem;
    padding: 0 2rem;
  }

  .video-card {
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: 2.5rem;
    align-items: center;
  }

  .video-card:nth-child(even) {
    grid-template-columns: 0.92fr 1.08fr;
  }

  .video-card:nth-child(even) .video-frame {
    order: 2;
  }

  .video-card:nth-child(even) .video-copy {
    order: 1;
  }

  .video-frame {
    width: 100%;
  }

  .video-frame iframe {
    width: 100%;
    height: 560px;
    display: block;
    border: 0;
    border-radius: 0;
  }

  .video-copy {
    text-align: center;
    padding: 0 2rem;
  }

  .section-label {
    font-size: 0.95rem;
    letter-spacing: 0.18em;
    color: #9b8f84;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .video-copy h2 {
    font-size: clamp(2.5rem, 3.2vw, 4rem);
    font-weight: 300;
    margin-bottom: 1.2rem;
    color: #8aa0a0;
    line-height: 1.18;
  }

  .video-copy p {
    line-height: 1.95;
    color: #4f4a45;
    font-size: 1.12rem;
  }

  .stories-section {
    padding-bottom: 4rem;
  }

  .stories-title {
    text-align: center;
    font-size: clamp(2.2rem, 4vw, 3.6rem);
    font-weight: 300;
    color: #8aa0a0;
    margin-bottom: 2.5rem;
    line-height: 1.15;
  }

  .stories-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .story-card {
    background: #faf8f5;
    border: 1px solid #eadfd4;
    border-radius: 22px;
    padding: 2rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.03);
    text-align: center;
  }

  .story-card h3 {
    font-size: 1.35rem;
    font-weight: 500;
    margin-bottom: 0.7rem;
    color: #8aa0a0;
  }

  .story-card p {
    color: #4f4a45;
    line-height: 1.8;
    font-size: 1.02rem;
  }

  @media (max-width: 1200px) {
    .video-frame iframe {
      height: 460px;
    }

    .video-copy {
      padding: 0 1rem;
    }
  }

  @media (max-width: 900px) {
    .video-card,
    .video-card:nth-child(even),
    .stories-grid {
      grid-template-columns: 1fr;
    }

    .video-card:nth-child(even) .video-frame,
    .video-card:nth-child(even) .video-copy {
      order: initial;
    }

    .videos-section {
      padding: 0 1rem;
      gap: 2rem;
    }

    .video-frame iframe {
      height: 300px;
      border-radius: 18px;
    }

    .video-copy {
      background: #faf8f5;
      border: 1px solid #eadfd4;
      border-radius: 24px;
      padding: 1.8rem 1.4rem;
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.03);
    }

    .video-copy h2 {
      font-size: clamp(2rem, 7vw, 2.8rem);
    }

    .video-copy p,
    .story-card p {
      font-size: 1rem;
    }

    .main-title {
      font-size: clamp(2.4rem, 9vw, 3.8rem);
    }

    .stories-title {
      font-size: 2.2rem;
    }
  }
</style>
