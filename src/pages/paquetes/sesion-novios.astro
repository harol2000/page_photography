---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const base = "https://harol2000.github.io/page_photography/";
---

<MainLayout title="Sesión de Novios | Studio27">
  <Header />

  <section class="package-detail">
    <div class="container narrow hero-top">
      <p class="kicker">SESIÓN PREVIA</p>
      <h1 class="main-title">Sesión de Novios</h1>
      <p class="intro">
        Antes de la boda hay una etapa hermosa: la de la complicidad, la emoción y la ilusión
        compartida. Esta sesión está pensada para capturar su esencia como pareja de una forma
        natural, relajada y auténtica.
      </p>

      <div class="prices-wrap">
        <div class="prices">
          <div class="price-card">
            <h2>S/ 550</h2>
            <p class="plan-name">Sesión clásica</p>
            <p>1 locación</p>
            <p>1 hora y media</p>
          </div>

          <div class="price-card">
            <h2>S/ 950</h2>
            <p class="plan-name">Sesión extendida</p>
            <p>2 locaciones</p>
            <p>Hasta 3 horas</p>
          </div>
        </div>
      </div>
    </div>

    <div class="editorial-block">
      <div class="editorial-media">
        <img
          src={`${base}images/622715162_122108711973204129_1385943999764202253_n.jpg`}
          alt="Sesión de novios"
        />
      </div>

      <div class="editorial-text">
        <div class="editorial-card">
          <p class="section-label">BEFORE YOUR WEDDING</p>
          <h2>
            Una experiencia previa a la
            <br />
            boda
          </h2>

          <p>
            Una sesión pensada para que se conecten, se diviertan y tengan recuerdos previos a la
            boda con una estética íntima y elegante.
          </p>

          <div class="mini-divider"></div>

          <p>
            <strong>Sesión clásica</strong>
            <br />
            1 locación | Dirección fotográfica
          </p>

          <p>
            <strong>Sesión extendida</strong>
            <br />
            2 locaciones | Más variedad de tomas
          </p>
        </div>
      </div>
    </div>

    <div class="editorial-block reverse">
      <div class="editorial-text">
        <div class="editorial-card">
          <p class="section-label">ENTREGA</p>
          <h2>
            Galería editada y lista para
            <br />
            compartir
          </h2>

          <p>
            Se entrega una selección editada profesionalmente en galería online privada.
          </p>

          <div class="mini-divider"></div>

          <p>
            Ideal para invitaciones, redes sociales, recuerdos impresos o material visual de la
            boda.
          </p>
        </div>
      </div>

      <div class="editorial-media">
        <img
          src={`${base}images/623917170_122108717205204129_8828546668175769016_n.jpg`}
          alt="Entrega sesión de novios"
        />
      </div>
    </div>

    <div class="terms">
      <div class="container narrow">
        <p class="kicker">INFORMACIÓN IMPORTANTE</p>
        <h2>Términos & Condiciones</h2>

        <div class="terms-grid">
          <article>
            <div class="term-icon-circle">▣</div>
            <p>La fecha se confirma con adelanto previo.</p>
          </article>

          <article>
            <div class="term-icon-circle">◔</div>
            <p>Puede reprogramarse por clima o motivos coordinados con anticipación.</p>
          </article>

          <article>
            <div class="term-icon-circle">⌂</div>
            <p>Las locaciones con ingreso o permiso especial corren por cuenta del cliente.</p>
          </article>

          <article>
            <div class="term-icon-circle">◷</div>
            <p>El traslado fuera de la ciudad se cotiza aparte.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap');

  .package-detail {
    padding: 4rem 0 0;
    font-family: 'Montserrat', sans-serif;
  }

  .narrow {
    max-width: 1120px;
    margin-inline: auto;
  }

  .hero-top {
    text-align: center;
    margin-bottom: 4rem;
  }

  .kicker {
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    color: #9b8f84;
    margin-bottom: 1rem;
  }

  .main-title {
    font-size: clamp(3rem, 5vw, 4.8rem);
    font-weight: 300;
    color: #8aa0a0;
    margin-bottom: 1rem;
    line-height: 1.08;
  }

  .intro {
    max-width: 840px;
    margin: 0 auto 2rem;
    font-size: 1.15rem;
    line-height: 1.9;
    color: #4f4a45;
  }

  .prices-wrap {
    max-width: 760px;
    margin: 0 auto;
  }

  .prices {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.4rem;
  }

  .price-card {
    background: #faf8f5;
    border: 1px solid #eadfd4;
    border-radius: 22px;
    padding: 2rem 1.4rem;
    text-align: center;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.03);
  }

  .price-card h2 {
    font-size: 3rem;
    font-weight: 300;
    color: #8aa0a0;
    margin-bottom: 0.5rem;
    line-height: 1.1;
  }

  .plan-name {
    font-size: 1.1rem;
    color: #8aa0a0;
    font-weight: 500;
    margin-bottom: 0.55rem;
  }

  .price-card p {
    margin: 0.28rem 0;
    color: #5a554f;
    font-size: 1rem;
  }

  .editorial-block {
    max-width: 100%;
    margin: 0 auto 2.5rem;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 2.5rem;
    align-items: center;
  }

  .editorial-block.reverse {
    grid-template-columns: 0.95fr 1.05fr;
  }

  .editorial-block.reverse .editorial-text {
    order: 1;
  }

  .editorial-block.reverse .editorial-media {
    order: 2;
  }

  .editorial-media img {
    width: 100%;
    height: 580px;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .editorial-text {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3rem 0 1rem;
  }

  .editorial-block.reverse .editorial-text {
    padding: 0 1rem 0 3rem;
  }

  .editorial-card {
    width: 100%;
    max-width: 520px;
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
    text-align: center;
    box-shadow: none;
  }

  .section-label {
    font-size: 0.95rem;
    letter-spacing: 0.18em;
    color: #9b8f84;
    margin-bottom: 1rem;
  }

  .editorial-card h2 {
    font-size: clamp(2.6rem, 3.4vw, 4rem);
    font-weight: 300;
    margin-bottom: 1.2rem;
    color: #8aa0a0;
    line-height: 1.18;
  }

  .editorial-card p {
    line-height: 1.95;
    color: #4f4a45;
    font-size: 1.16rem;
  }

  .mini-divider {
    width: 72px;
    height: 1px;
    background: #d8cbbf;
    margin: 1.25rem auto;
  }

  .terms {
    padding: 4rem 0;
  }

  .terms h2 {
    text-align: center;
    font-size: 2.8rem;
    font-weight: 300;
    color: #8aa0a0;
    margin-bottom: 2rem;
    line-height: 1.2;
  }

  .terms-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .terms-grid article {
    background: #efe3d8;
    border-radius: 22px;
    padding: 2rem;
    min-height: 220px;
    display: grid;
    place-items: center;
    text-align: center;
  }

  .terms-grid article p {
    font-size: 1.08rem;
    line-height: 1.8;
    color: #4f4a45;
  }

  .term-icon-circle {
    width: 58px;
    height: 58px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    margin: 0 auto 1rem;
    background: #b2760c;
    color: white;
    font-size: 1.5rem;
  }

  @media (max-width: 1200px) {
    .editorial-text {
      padding: 0 2rem;
    }

    .editorial-block.reverse .editorial-text {
      padding: 0 2rem;
    }

    .editorial-media img {
      height: 470px;
    }
  }

  @media (max-width: 900px) {
    .prices,
    .terms-grid,
    .editorial-block,
    .editorial-block.reverse {
      grid-template-columns: 1fr;
    }

    .editorial-block {
      gap: 1.5rem;
      padding: 0 1rem;
    }

    .editorial-block.reverse .editorial-text,
    .editorial-block.reverse .editorial-media {
      order: initial;
    }

    .editorial-media img {
      height: auto;
      min-height: 300px;
      border-radius: 18px;
    }

    .editorial-text,
    .editorial-block.reverse .editorial-text {
      padding: 0;
    }

    .editorial-card {
      background: #faf8f5;
      border: 1px solid #eadfd4;
      border-radius: 24px;
      padding: 1.8rem 1.4rem;
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.03);
    }

    .editorial-card h2 {
      font-size: clamp(2rem, 7vw, 2.8rem);
    }

    .editorial-card p,
    .terms-grid article p {
      font-size: 1rem;
    }

    .main-title {
      font-size: clamp(2.4rem, 9vw, 3.8rem);
    }

    .terms h2 {
      font-size: 2.2rem;
    }
  }
</style>
