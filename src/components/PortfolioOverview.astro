---
import type { ImageMetadata } from "astro";
import { galleries } from "../data/galleries";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/galerias/**/*.{jpg,jpeg,png,webp,jfif}",
  { eager: true }
);

function getCover(slug: string): ImageMetadata | null {
  const match = Object.entries(allImages).find(([path]) =>
    path.includes(`/galerias/${slug}/`)
  );

  return match ? match[1].default : null;
}

function getVariant(cover: ImageMetadata | null) {
  if (!cover) return "is-standard";

  const ratio = cover.width / cover.height;

  if (ratio > 1.28) return "is-wide";
  if (ratio < 0.82) return "is-tall";

  return "is-standard";
}

function getAspectRatio(cover: ImageMetadata | null) {
  return cover ? `${cover.width} / ${cover.height}` : "4 / 5";
}
---

<section class="section portfolio-section">
  <div class="container portfolio-shell">
    <div class="portfolio-intro">
      <p class="eyebrow">Portafolio</p>
      <h1 class="title">Historias reales, luz honesta y momentos que siguen vivos</h1>
      <p class="text">
        Un recorrido por sesiones pensadas para sentirse cercanas, elegantes y llenas de verdad.
        Cada historia mantiene su propio ritmo, su propia atmósfera y una forma distinta de
        habitar la emoción.
      </p>
    </div>

    <div class="portfolio-grid">
      {galleries.map((gallery) => {
        const cover = getCover(gallery.slug);
        const variant = getVariant(cover);

        return (
          <a
            href={`${base}galeria/${gallery.slug}/`}
            class={`portfolio-card ${variant}`}
            style={`--card-ratio: ${getAspectRatio(cover)};`}
          >
            {cover && (
              <div class="portfolio-media">
                <img src={cover.src} alt={gallery.title} class="portfolio-image" />
              </div>
            )}

            <div class="portfolio-copy">
              <p class="portfolio-kicker">Portafolio</p>
              <h2>{gallery.title}</h2>
              <p>{gallery.description}</p>
              <span>Abrir historia</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .portfolio-shell {
    display: grid;
    gap: 2rem;
  }

  .portfolio-intro {
    max-width: 760px;
  }

  .portfolio-intro .title {
    max-width: 14ch;
  }

  .portfolio-intro .text {
    max-width: 62ch;
    line-height: 1.85;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-auto-flow: dense;
    gap: 1rem;
    align-items: start;
  }

  .portfolio-card {
    position: relative;
    grid-column: span 4;
    overflow: hidden;
    border-radius: 24px;
    background: #ddd7d0;
    box-shadow: var(--shadow);
    color: white;
    isolation: isolate;
  }

  .portfolio-card.is-wide {
    grid-column: span 7;
  }

  .portfolio-card.is-tall {
    grid-column: span 5;
  }

  .portfolio-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(12, 12, 12, 0.06) 0%, rgba(12, 12, 12, 0.58) 100%);
    z-index: 1;
  }

  .portfolio-media {
    aspect-ratio: var(--card-ratio);
    min-height: 280px;
  }

  .portfolio-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  .portfolio-card:hover .portfolio-image {
    transform: scale(1.04);
  }

  .portfolio-copy {
    position: absolute;
    inset: auto 0 0;
    z-index: 2;
    padding: 1.4rem;
    display: grid;
    gap: 0.65rem;
  }

  .portfolio-kicker {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.78);
  }

  .portfolio-copy h2 {
    font-size: clamp(1.6rem, 2.2vw, 2.6rem);
    font-weight: 400;
    line-height: 0.98;
  }

  .portfolio-copy p {
    max-width: 32ch;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.9);
  }

  .portfolio-copy span {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    font-weight: 600;
  }

  @media (max-width: 1100px) {
    .portfolio-card,
    .portfolio-card.is-wide,
    .portfolio-card.is-tall {
      grid-column: span 6;
    }
  }

  @media (max-width: 720px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
    }

    .portfolio-card,
    .portfolio-card.is-wide,
    .portfolio-card.is-tall {
      grid-column: span 1;
    }

    .portfolio-media {
      min-height: 240px;
    }

    .portfolio-copy {
      padding: 1.1rem;
    }

    .portfolio-copy h2 {
      font-size: 1.8rem;
    }
  }
</style>
