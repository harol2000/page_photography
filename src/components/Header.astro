---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
const currentPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

const navItems = [
  { label: "Inicio", route: "/" },
  { label: "Stalk me", route: "/stalk-me/" },
  { label: "Cinematics", route: "/cinematics/" },
  { label: "Portafolio", route: "/portafolio/", aliases: ["/galeria/"] },
  { label: "Testimonios", route: "/testimonios/" },
  { label: "Paquetes", route: "/paquetes/" },
  { label: "Contacto", route: "/contacto/" }
];

function withBase(route: string) {
  if (route === "/") return base;
  return `${base}${route.replace(/^\/|\/$/g, "")}/`;
}

function isActive(item: { route: string; aliases?: string[] }) {
  const candidates = [item.route, ...(item.aliases ?? [])].map(withBase);

  return candidates.some((candidate) => {
    if (candidate === base) {
      return currentPath === base;
    }

    return currentPath === candidate || currentPath.startsWith(candidate);
  });
}
---

<header class="header">
  <div class="container header-inner">
    <a href={withBase("/")} class="brand">
      <img
        src="https://harol2000.github.io/page_photography/images/LOGO_FRANKTUCNO.png"
        alt="Logo"
        class="brand-logo"
      />
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="nav desktop-nav">
      {navItems.map((item) => (
        <a href={withBase(item.route)} class={isActive(item) ? "is-active" : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <nav class="mobile-nav" id="mobile-menu">
    {navItems.map((item) => (
      <a href={withBase(item.route)} class={isActive(item) ? "is-active" : undefined}>
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const toggle = document.querySelector(".menu-toggle");
  const mobileMenu = document.querySelector(".mobile-nav");

  if (toggle && mobileMenu) {
    toggle.addEventListener("click", () => {
      const isOpen = mobileMenu.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(isOpen));
    });

    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        mobileMenu.classList.remove("is-open");
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 60;
    background: rgba(247, 244, 241, 0.96);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    min-height: 110px;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 1.6rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
  }

  .brand-logo {
    height: 64px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .nav {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 1rem;
    justify-self: center;
    flex-wrap: wrap;
  }

  .nav a {
    position: relative;
    padding-top: 1.35rem;
    min-width: 82px;
    text-align: center;
    color: #8d8a84;
    font-size: 0.95rem;
    font-weight: 400;
    transition: color 0.25s ease;
  }

  .nav a::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 10px);
    height: 2px;
    background: #6f7f7f;
    opacity: 0.55;
    transition: opacity 0.25s ease, background 0.25s ease;
  }

  .nav a:hover {
    color: #6f7f7f;
  }

  .nav a:hover::before,
  .nav a.is-active::before {
    opacity: 1;
    background: #8aa0a0;
  }

  .nav a.is-active {
    color: #8aa0a0;
  }

  .menu-toggle {
    display: none;
    width: 46px;
    height: 46px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: white;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
  }

  .menu-toggle span {
    width: 20px;
    height: 2px;
    background: #5b554f;
    display: block;
    border-radius: 999px;
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 1rem;
    padding: 0 1.2rem 1.4rem;
    width: min(var(--container), calc(100% - 2rem));
    margin: 0 auto;
    text-align: center;
  }

  .mobile-nav a {
    color: #6e6760;
    font-size: 1rem;
  }

  .mobile-nav a.is-active {
    color: #8aa0a0;
  }

  .mobile-nav.is-open {
    display: flex;
  }

  @media (max-width: 1180px) {
    .nav {
      gap: 0.55rem;
    }

    .nav a {
      min-width: 74px;
      font-size: 0.88rem;
    }
  }

  @media (max-width: 980px) {
    .header-inner {
      min-height: 82px;
      grid-template-columns: 1fr auto;
    }

    .desktop-nav {
      display: none;
    }

    .menu-toggle {
      display: inline-flex;
      justify-self: end;
    }

    .brand-logo {
      height: 50px;
    }
  }
</style>
