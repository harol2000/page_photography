<header class="header">
  <div class="container header-inner">
    <a href="https://harol2000.github.io/page_photography/" class="brand">
      <img
        src="https://harol2000.github.io/page_photography/images/LOGO_FRANKTUCNO.png"
        alt="Logo"
        class="brand-logo"
      />
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="nav desktop-nav">
      <a href="https://harol2000.github.io/page_photography/" class="is-active">Inicio</a>
      <a href="https://harol2000.github.io/page_photography/galeria/">Galería</a>
      <a href="https://harol2000.github.io/page_photography/cinematics/">Cinematics</a>
      <a href="https://harol2000.github.io/page_photography/paquetes/">Paquetes</a>
      <a href="https://harol2000.github.io/page_photography/contacto/">Contacto</a>
    </nav>
  </div>

  <nav class="mobile-nav" id="mobile-menu">
    <a href="https://harol2000.github.io/page_photography/">Inicio</a>
    <a href="https://harol2000.github.io/page_photography/galeria/">Galería</a>
    <a href="https://harol2000.github.io/page_photography/cinematics/">Cinematics</a>
    <a href="https://harol2000.github.io/page_photography/paquetes/">Paquetes</a>
    <a href="https://harol2000.github.io/page_photography/contacto/">Contacto</a>
  </nav>
</header>

<script>
  const toggle = document.querySelector(".menu-toggle");
  const mobileMenu = document.querySelector(".mobile-nav");

  if (toggle && mobileMenu) {
    toggle.addEventListener("click", () => {
      const isOpen = mobileMenu.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(isOpen));
    });
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 60;
    background: rgba(247, 244, 241, 0.96);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    min-height: 110px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
  }

  .brand-logo {
    height: 64px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .nav {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 2.2rem;
    justify-self: center;
  }

  .nav a {
    position: relative;
    padding-top: 1.6rem;
    min-width: 110px;
    text-align: center;
    color: #8d8a84;
    font-size: 1.05rem;
    font-weight: 400;
    transition: color 0.25s ease;
  }

  .nav a::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 118px;
    height: 2px;
    background: #6f7f7f;
    opacity: 0.55;
    transition: opacity 0.25s ease, background 0.25s ease;
  }

  .nav a:hover {
    color: #6f7f7f;
  }

  .nav a:hover::before,
  .nav a.is-active::before {
    opacity: 1;
    background: #8aa0a0;
  }

  .nav a.is-active {
    color: #8aa0a0;
  }

  .menu-toggle {
    display: none;
    width: 46px;
    height: 46px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: white;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
  }

  .menu-toggle span {
    width: 20px;
    height: 2px;
    background: #5b554f;
    display: block;
    border-radius: 999px;
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 1rem;
    padding: 0 1.2rem 1.4rem;
    width: min(var(--container), calc(100% - 2rem));
    margin: 0 auto;
    text-align: center;
  }

  .mobile-nav a {
    color: #6e6760;
    font-size: 1rem;
  }

  .mobile-nav.is-open {
    display: flex;
  }

  @media (max-width: 1100px) {
    .nav {
      gap: 1.2rem;
    }

    .nav a {
      min-width: 92px;
      font-size: 0.98rem;
    }

    .nav a::before {
      width: 92px;
    }
  }

  @media (max-width: 860px) {
    .header-inner {
      min-height: 82px;
      grid-template-columns: 1fr auto;
    }

    .desktop-nav {
      display: none;
    }

    .menu-toggle {
      display: inline-flex;
      justify-self: end;
    }

    .brand-logo {
      height: 50px;
    }
  }
</style>
