<header class="header">
  <div class="container header-inner">
    <a href="https://harol2000.github.io/page_photography/" class="brand">
      <img
        src="https://harol2000.github.io/page_photography/images/logo.png"
        alt="Logo"
        class="brand-logo"
      />
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="nav desktop-nav">
      <a href="https://harol2000.github.io/page_photography/" class="nav-link is-active">Inicio</a>
      <a href="https://harol2000.github.io/page_photography/galeria/" class="nav-link">Galería</a>
      <a href="https://harol2000.github.io/page_photography/paquetes/" class="nav-link">Paquetes</a>
      <a href="https://harol2000.github.io/page_photography/contacto/" class="nav-link">Contacto</a>
    </nav>
  </div>

  <nav class="mobile-nav" id="mobile-menu">
    <a href="https://harol2000.github.io/page_photography/">Inicio</a>
    <a href="https://harol2000.github.io/page_photography/galeria/">Galería</a>
    <a href="https://harol2000.github.io/page_photography/paquetes/">Paquetes</a>
    <a href="https://harol2000.github.io/page_photography/contacto/">Contacto</a>
  </nav>
</header>

<script>
  const toggle = document.querySelector(".menu-toggle");
  const mobileMenu = document.querySelector(".mobile-nav");

  if (toggle && mobileMenu) {
    toggle.addEventListener("click", () => {
      const isOpen = mobileMenu.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(isOpen));
    });
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 60;
    background: rgba(247, 244, 241, 0.98);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(120, 110, 100, 0.12);
  }

  .header-inner {
    min-height: 108px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-self: start;
  }

  .brand-logo {
    height: 58px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .desktop-nav {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 1rem;
    justify-self: center;
  }

  .nav-link {
    position: relative;
    min-width: 120px;
    padding-top: 1.7rem;
    text-align: center;
    color: #928d87;
    font-size: 1.02rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    transition: color 0.25s ease;
  }

  .nav-link::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 112px;
    height: 2px;
    background: #8d8a84;
    opacity: 0.7;
    transition: all 0.25s ease;
  }

  .nav-link:hover {
    color: #7f9898;
  }

  .nav-link:hover::before,
  .nav-link.is-active::before {
    background: #8ea1a1;
    opacity: 1;
  }

  .nav-link.is-active {
    color: #8ea1a1;
  }

  .menu-toggle {
    display: none;
    width: 46px;
    height: 46px;
    border: 1px solid rgba(120, 110, 100, 0.18);
    border-radius: 12px;
    background: white;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
  }

  .menu-toggle span {
    width: 20px;
    height: 2px;
    background: #5d5751;
    display: block;
    border-radius: 999px;
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 1rem;
    padding: 0 1.2rem 1.4rem;
    width: min(var(--container), calc(100% - 2rem));
    margin: 0 auto;
    text-align: center;
  }

  .mobile-nav a {
    color: #6f6962;
    font-size: 1rem;
  }

  .mobile-nav.is-open {
    display: flex;
  }

  @media (max-width: 1100px) {
    .nav-link {
      min-width: 98px;
      font-size: 0.96rem;
    }

    .nav-link::before {
      width: 92px;
    }
  }

  @media (max-width: 860px) {
    .header-inner {
      min-height: 82px;
      grid-template-columns: 1fr auto;
    }

    .desktop-nav {
      display: none;
    }

    .menu-toggle {
      display: inline-flex;
      justify-self: end;
    }

    .brand-logo {
      height: 48px;
    }
  }
</style>
