---
const services = [
  { title: "sadad", image: "/images/quinceanios.png" },
  { title: "Retratos", image: "/images/retratos.png" },
  { title: "Bodas", image: "/images/bodas.png" },
  { title: "Corporativos", image: "/images/corporativos.png" },
  { title: "Infantiles", image: "/images/infantiles.png" },
  { title: "Sesiones especiales", image: "/images/retratos.png" },
];
---

<section id="servicios" class="section services-section">
  <div class="container">
    <div class="services-heading">
      <p class="eyebrow">Especialidades</p>
      <h2 class="section-title">Servicios fotográficos</h2>
      <p class="section-text">
        Una propuesta visual pensada para momentos únicos, proyectos personales
        y necesidades de marca.
      </p>
    </div>

    <div class="services-grid">
      {services.map((service, i) => (
        <article class="service-card" style={`animation-delay:${i * 80}ms`}>
          <div class="service-image-wrap">
            <img src={service.image} alt={service.title} class="service-image" />
            <div class="service-gradient"></div>
            <span class="service-badge">Portfolio</span>
          </div>

          <div class="service-content">
            <h3>{service.title}</h3>
            <a href="#contacto" class="service-link">Consultar sesión</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-heading {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .services-heading .section-text {
    margin-inline: auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.4rem;
  }

  .service-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.28s ease, box-shadow 0.28s ease;
    animation: fadeUp 0.7s ease both;
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 34px rgba(0, 0, 0, 0.09);
  }

.service-image-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 4 / 5;
  overflow: hidden;
  background: #ddd;
}

.service-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

  .service-card:hover .service-image {
    transform: scale(1.04);
  }

  .service-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.28), rgba(0,0,0,0.02));
  }

  .service-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: rgba(255,255,255,0.8);
    color: #473d35;
    backdrop-filter: blur(8px);
  }

  .service-content {
    padding: 1.2rem 1.1rem 1.25rem;
  }

  .service-content h3 {
    font-size: clamp(1.15rem, 2vw, 1.6rem);
    line-height: 1.15;
    margin-bottom: 0.6rem;
  }

  .service-link {
    font-size: 0.95rem;
    color: var(--accent-dark);
    font-weight: 700;
  }

  @media (max-width: 980px) {
    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .service-content {
      padding: 1rem;
    }

    .service-image-wrap {
      aspect-ratio: 5 / 6;
    }
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>